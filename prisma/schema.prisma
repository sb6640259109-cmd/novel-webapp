generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id          String   @id @default(uuid()) @db.VarChar(191)
  username    String   @unique @db.VarChar(50)
  email       String   @unique @db.VarChar(191)
  password    String   @db.VarChar(191)
  firebaseUid String?  @unique @db.VarChar(191)
  role        String   @default("READER") @db.VarChar(20)
  displayName String?  @db.VarChar(100)
  bio         String?  @db.VarChar(500)
  avatarUrl   String?  @db.VarChar(2048)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Novel {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(191)
  author      String   @db.VarChar(191)
  genre       String   @db.VarChar(100)
  description String   @db.Text
  content     String?  @db.LongText
  rating      Float    @default(0)
  image       String?  @db.VarChar(2048)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
